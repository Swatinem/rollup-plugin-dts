{
  "extends": [
    "config:recommended",
    "schedule:weekly",
    "group:allNonMajor",
    ":automergeMinor",
    ":automergeBranch",
    ":automergeRequireAllStatusChecks"
  ],
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "description": "Ignore Node engine updates",
      "matchManagers": ["npm"],
      "matchDepTypes": ["engines"],
      "matchDepNames": ["node"],
      "enabled": false
    },
    {
      "description": "Ignore peerDependencies",
      "matchManagers": ["npm"],
      "matchDepTypes": ["peerDependencies"],
      "enabled": false
    }
  ]
}
